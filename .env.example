# ═════════════════════════════════════════════════════════════════
# honey_money_bot — пример конфигурации.
# Скопируйте в .env и заполните своими значениями.
# .env не коммитится (см. .gitignore).
# ═════════════════════════════════════════════════════════════════

# ─── ArenaGo / тестовый торговый контур MOEX ─────────────────────
# КРИТИЧНО: имя переменной должно быть именно SANDBOX_API_KEY —
# на этапе 2 organizers подменят её на новые ключи автоматически.
SANDBOX_API_KEY=
SANDBOX_API_URL=https://arenago.ru/api
BOT_NAME="honey money"

# ─── Polza.ai (агрегатор open-source LLM) ────────────────────────
# Получить ключ: https://polza.ai/dashboard/api-keys
# Используемые модели: mistral-large (Apache 2.0), deepseek-chat (MIT)
POLZA_API_KEY=
POLZA_BASE_URL=https://api.polza.ai/api/v1

# ─── MOEX AlgoPack (опционально, расширенные рыночные данные) ───
# Заявка: algopack@moex.com. Без него работаем через публичный ISS.
MOEX_ALGOPACK_KEY=
MOEX_ALGOPACK_BASE_URL=https://apim.moex.com/iss

# ─── Конфигурация работы бота ────────────────────────────────────
# /data — постоянное хранилище (state, audit, stop_loss, turnover)
DATA_DIR=/data
TRADING_ENABLED=true
DECISION_INTERVAL_SECONDS=600

# ─── Риск-параметры ──────────────────────────────────────────────
# 20% от стартового капитала на одну сделку — hard cap.
MAX_ORDER_CASH_SHARE=0.20
MIN_CASH_RESERVE=10000
MAX_DAILY_TRADES=1000
ALLOW_SHORTS=true

# ─── Health endpoint (read-only, для мониторинга) ────────────────
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# ─── Сетевые таймауты ────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30
REQUEST_MAX_RETRIES=3
STOP_WATCH_INTERVAL_SECONDS=60

# ─── Дополнительно (опционально, новостные API; не используются) ─
# BLOOMBERG_API_KEY=
# MARKETPSYCH_API_KEY=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
